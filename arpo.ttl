@prefix arpo:  <https://example.org/arpo#> .
@prefix owl:   <http://www.w3.org/2002/07/owl#> .
@prefix rdf:   <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs:  <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd:   <http://www.w3.org/2001/XMLSchema#> .
@prefix dc:    <http://purl.org/dc/terms/> .
@prefix skos:  <http://www.w3.org/2004/02/skos/core#> .

# ─────────────────────────────────────────────────────────────────────────────
# Ontology Declaration
# ─────────────────────────────────────────────────────────────────────────────

<https://example.org/arpo>
    a owl:Ontology ;
    dc:title        "Academic Research Publication Ontology (ARPO)" ;
    dc:description  "A formal OWL 2 DL ontology for representing academic research publications, authors, venues, institutions, citation relationships, funding, and open access status." ;
    dc:creator      "Fırat Kaya Özgenç" ;
    dc:date         "2026-05-05" ;
    dc:license      <https://creativecommons.org/licenses/by/4.0/> ;
    owl:versionIRI  <https://example.org/arpo/2.0> ;
    owl:priorVersion <https://example.org/arpo/1.0> ;
    skos:changeNote "v2.0: Added ResearchGroup, Grant, FundingBody, AffiliationRecord, OpenAccessStatus, PeerReviewRecord, Preprint classes. Added 6 new object properties and 4 new data properties. Modelling follows MOMo methodology with record and controlled-vocabulary patterns." .


# ─────────────────────────────────────────────────────────────────────────────
# CLASSES — v1 (retained)
# ─────────────────────────────────────────────────────────────────────────────

# ── Publications ─────────────────────────────────────────────────────────────

arpo:Publication
    a owl:Class ;
    rdfs:label   "Publication" ;
    rdfs:comment "The top-level class for all types of academic research outputs." .

arpo:JournalArticle
    a owl:Class ;
    rdfs:subClassOf arpo:Publication ;
    rdfs:label   "Journal Article" ;
    rdfs:comment "A peer-reviewed article published in a scholarly journal." .

arpo:ConferencePaper
    a owl:Class ;
    rdfs:subClassOf arpo:Publication ;
    rdfs:label   "Conference Paper" ;
    rdfs:comment "A paper accepted and presented at an academic conference or workshop." .

arpo:BookChapter
    a owl:Class ;
    rdfs:subClassOf arpo:Publication ;
    rdfs:label   "Book Chapter" ;
    rdfs:comment "A chapter or section published within an edited academic book." .

arpo:Thesis
    a owl:Class ;
    rdfs:subClassOf arpo:Publication ;
    rdfs:label   "Thesis" ;
    rdfs:comment "A doctoral dissertation or master's thesis submitted to an academic institution." .

arpo:TechnicalReport
    a owl:Class ;
    rdfs:subClassOf arpo:Publication ;
    rdfs:label   "Technical Report" ;
    rdfs:comment "A formal report describing the results or progress of technical research." .

# NEW v2
arpo:Preprint
    a owl:Class ;
    rdfs:subClassOf arpo:Publication ;
    rdfs:label   "Preprint" ;
    rdfs:comment "A version of a research paper made publicly available before formal peer review, typically deposited on a preprint server such as arXiv or bioRxiv." .

[ a owl:AllDisjointClasses ;
  owl:members ( arpo:JournalArticle arpo:ConferencePaper arpo:BookChapter
                arpo:Thesis arpo:TechnicalReport arpo:Preprint ) ] .


# ── Persons ──────────────────────────────────────────────────────────────────

arpo:Person
    a owl:Class ;
    rdfs:label   "Person" ;
    rdfs:comment "A human being involved in academic research activities." .

arpo:Researcher
    a owl:Class ;
    rdfs:subClassOf arpo:Person ;
    rdfs:label   "Researcher" ;
    rdfs:comment "A person who conducts academic research." .

arpo:Author
    a owl:Class ;
    rdfs:subClassOf arpo:Researcher ;
    rdfs:label   "Author" ;
    rdfs:comment "A researcher who has authored one or more publications." .

arpo:Reviewer
    a owl:Class ;
    rdfs:subClassOf arpo:Researcher ;
    rdfs:label   "Reviewer" ;
    rdfs:comment "A researcher who peer-reviews academic manuscripts." .


# ── Institutions ─────────────────────────────────────────────────────────────

arpo:Institution
    a owl:Class ;
    rdfs:label   "Institution" ;
    rdfs:comment "An organisation with which researchers may be affiliated." .

arpo:University
    a owl:Class ;
    rdfs:subClassOf arpo:Institution ;
    rdfs:label   "University" ;
    rdfs:comment "A higher-education institution that conducts research." .

arpo:ResearchInstitute
    a owl:Class ;
    rdfs:subClassOf arpo:Institution ;
    rdfs:label   "Research Institute" ;
    rdfs:comment "A dedicated research organisation, not necessarily degree-granting." .

arpo:Company
    a owl:Class ;
    rdfs:subClassOf arpo:Institution ;
    rdfs:label   "Company" ;
    rdfs:comment "An industrial or commercial organisation engaged in research." .

# NEW v2 — MOMo Parthood/Membership pattern
arpo:ResearchGroup
    a owl:Class ;
    rdfs:subClassOf arpo:Institution ;
    rdfs:label   "Research Group" ;
    rdfs:comment "A named research group or laboratory operating within a university or research institute." .

[ a owl:AllDisjointClasses ;
  owl:members ( arpo:University arpo:ResearchInstitute arpo:Company arpo:ResearchGroup ) ] .


# ── Publication Venues ───────────────────────────────────────────────────────

arpo:PublicationVenue
    a owl:Class ;
    rdfs:label   "Publication Venue" ;
    rdfs:comment "A channel or forum where academic research is formally published or presented." .

arpo:Journal
    a owl:Class ;
    rdfs:subClassOf arpo:PublicationVenue ;
    rdfs:label   "Journal" ;
    rdfs:comment "A periodical publication containing peer-reviewed academic articles." .

arpo:Conference
    a owl:Class ;
    rdfs:subClassOf arpo:PublicationVenue ;
    rdfs:label   "Conference" ;
    rdfs:comment "An academic event at which research papers are presented and published in proceedings." .

arpo:Workshop
    a owl:Class ;
    rdfs:subClassOf arpo:Conference ;
    rdfs:label   "Workshop" ;
    rdfs:comment "A smaller, more focused academic event often co-located with a major conference." .

[ a owl:AllDisjointClasses ;
  owl:members ( arpo:Journal arpo:Conference ) ] .


# ── Funding — NEW v2 ─────────────────────────────────────────────────────────

arpo:Grant
    a owl:Class ;
    rdfs:label   "Grant" ;
    rdfs:comment "A funded research grant associated with one or more publications." .

arpo:FundingBody
    a owl:Class ;
    rdfs:label   "Funding Body" ;
    rdfs:comment "An organisation that provides research funding, such as a national science foundation, charity, or government agency." .


# ── Status and Records — NEW v2 (MOMo patterns) ──────────────────────────────

arpo:OpenAccessStatus
    a owl:Class ;
    rdfs:label   "Open Access Status" ;
    rdfs:comment "The open access category of a publication. Controlled vocabulary: gold, green, bronze, closed. Follows the MOMo controlled-vocabulary (purple-box) pattern." .

arpo:PeerReviewRecord
    a owl:Class ;
    rdfs:label   "Peer Review Record" ;
    rdfs:comment "A record capturing the peer-review status of a publication, including whether it was reviewed and at which venue. Follows the MOMo provenance pattern." .

# MOMo Record pattern: AffiliationRecord reifies the time-bounded
# relationship between an Author and an Institution.
arpo:AffiliationRecord
    a owl:Class ;
    rdfs:label   "Affiliation Record" ;
    rdfs:comment "A time-bounded record linking an Author to an Institution for a given period. Follows the MOMo record pattern, which reifies relationships that change over time." .


# ── Other Concepts ───────────────────────────────────────────────────────────

arpo:ResearchTopic
    a owl:Class ;
    rdfs:label   "Research Topic" ;
    rdfs:comment "A subject area or thematic domain of academic research." .

arpo:Keyword
    a owl:Class ;
    rdfs:label   "Keyword" ;
    rdfs:comment "A term or phrase assigned to a publication to describe its content." .

arpo:Citation
    a owl:Class ;
    rdfs:label   "Citation" ;
    rdfs:comment "A formal reference from one publication to another." .

arpo:Publisher
    a owl:Class ;
    rdfs:label   "Publisher" ;
    rdfs:comment "An organisation responsible for producing and distributing publications." .


# ─────────────────────────────────────────────────────────────────────────────
# OBJECT PROPERTIES — v1 (retained)
# ─────────────────────────────────────────────────────────────────────────────

arpo:hasAuthor
    a owl:ObjectProperty ;
    rdfs:domain  arpo:Publication ;
    rdfs:range   arpo:Author ;
    rdfs:label   "has author" ;
    rdfs:comment "Relates a publication to one of its authors." .

arpo:isAuthorOf
    a owl:ObjectProperty ;
    owl:inverseOf arpo:hasAuthor ;
    rdfs:domain  arpo:Author ;
    rdfs:range   arpo:Publication ;
    rdfs:label   "is author of" ;
    rdfs:comment "Relates an author to a publication they have authored." .

arpo:hasCoAuthor
    a owl:ObjectProperty , owl:SymmetricProperty ;
    rdfs:domain  arpo:Author ;
    rdfs:range   arpo:Author ;
    rdfs:label   "has co-author" ;
    rdfs:comment "Relates two authors who have co-authored at least one publication together." .

arpo:isAffiliatedWith
    a owl:ObjectProperty ;
    rdfs:domain  arpo:Researcher ;
    rdfs:range   arpo:Institution ;
    rdfs:label   "is affiliated with" ;
    rdfs:comment "Direct affiliation link between a researcher and an institution (simplified role-chain shortcut, following Norouzi et al. 2025)." .

arpo:hasAffiliation
    a owl:ObjectProperty ;
    owl:inverseOf arpo:isAffiliatedWith ;
    rdfs:domain  arpo:Institution ;
    rdfs:range   arpo:Researcher ;
    rdfs:label   "has affiliation" ;
    rdfs:comment "Relates an institution to a researcher affiliated with it." .

arpo:publishedIn
    a owl:ObjectProperty ;
    rdfs:domain  arpo:Publication ;
    rdfs:range   arpo:PublicationVenue ;
    rdfs:label   "published in" ;
    rdfs:comment "Relates a publication to the venue in which it was published." .

arpo:publishedBy
    a owl:ObjectProperty ;
    rdfs:domain  arpo:Publication ;
    rdfs:range   arpo:Publisher ;
    rdfs:label   "published by" ;
    rdfs:comment "Relates a publication to the publisher responsible for it." .

arpo:cites
    a owl:ObjectProperty , owl:IrreflexiveProperty ;
    rdfs:domain  arpo:Publication ;
    rdfs:range   arpo:Publication ;
    rdfs:label   "cites" ;
    rdfs:comment "Relates a publication to another publication it cites." .

arpo:isCitedBy
    a owl:ObjectProperty ;
    owl:inverseOf arpo:cites ;
    rdfs:domain  arpo:Publication ;
    rdfs:range   arpo:Publication ;
    rdfs:label   "is cited by" ;
    rdfs:comment "Relates a publication to publications that cite it." .

arpo:hasResearchTopic
    a owl:ObjectProperty ;
    rdfs:domain  arpo:Publication ;
    rdfs:range   arpo:ResearchTopic ;
    rdfs:label   "has research topic" ;
    rdfs:comment "Relates a publication to a research topic it covers." .

arpo:hasKeyword
    a owl:ObjectProperty ;
    rdfs:domain  arpo:Publication ;
    rdfs:range   arpo:Keyword ;
    rdfs:label   "has keyword" ;
    rdfs:comment "Relates a publication to one of its descriptor keywords." .

arpo:representsArea
    a owl:ObjectProperty ;
    rdfs:domain  arpo:Keyword ;
    rdfs:range   arpo:ResearchTopic ;
    rdfs:label   "represents area" ;
    rdfs:comment "Relates a keyword to the broader research topic it represents." .


# ─────────────────────────────────────────────────────────────────────────────
# OBJECT PROPERTIES — NEW v2
# ─────────────────────────────────────────────────────────────────────────────

# MOMo Record pattern: links Author to time-bounded AffiliationRecord
arpo:hasAffiliationRecord
    a owl:ObjectProperty ;
    rdfs:domain  arpo:Author ;
    rdfs:range   arpo:AffiliationRecord ;
    rdfs:label   "has affiliation record" ;
    rdfs:comment "Relates an author to a time-bounded affiliation record. Implements the MOMo record pattern to allow tracking of affiliation changes over time." .

arpo:affiliatedInstitution
    a owl:ObjectProperty ;
    rdfs:domain  arpo:AffiliationRecord ;
    rdfs:range   arpo:Institution ;
    rdfs:label   "affiliated institution" ;
    rdfs:comment "The institution named in an affiliation record." .

# Funding
arpo:hasFunding
    a owl:ObjectProperty ;
    rdfs:domain  arpo:Publication ;
    rdfs:range   arpo:Grant ;
    rdfs:label   "has funding" ;
    rdfs:comment "Relates a publication to a grant that funded the research." .

arpo:fundedBy
    a owl:ObjectProperty ;
    rdfs:domain  arpo:Grant ;
    rdfs:range   arpo:FundingBody ;
    rdfs:label   "funded by" ;
    rdfs:comment "Relates a grant to the funding body that issued it." .

# Open access status (MOMo controlled vocabulary pattern)
arpo:hasOpenAccessStatus
    a owl:ObjectProperty , owl:FunctionalProperty ;
    rdfs:domain  arpo:Publication ;
    rdfs:range   arpo:OpenAccessStatus ;
    rdfs:label   "has open access status" ;
    rdfs:comment "Relates a publication to its open access category (gold, green, bronze, or closed)." .

# Peer review
arpo:hasPeerReviewRecord
    a owl:ObjectProperty , owl:FunctionalProperty ;
    rdfs:domain  arpo:Publication ;
    rdfs:range   arpo:PeerReviewRecord ;
    rdfs:label   "has peer review record" ;
    rdfs:comment "Relates a publication to a record of its peer-review status." .

# Group membership
arpo:memberOf
    a owl:ObjectProperty ;
    rdfs:domain  arpo:Author ;
    rdfs:range   arpo:ResearchGroup ;
    rdfs:label   "member of" ;
    rdfs:comment "Relates an author to a research group they belong to." .


# ─────────────────────────────────────────────────────────────────────────────
# DATA PROPERTIES — v1 (retained)
# ─────────────────────────────────────────────────────────────────────────────

arpo:hasTitle
    a owl:DatatypeProperty , owl:FunctionalProperty ;
    rdfs:domain  arpo:Publication ;
    rdfs:range   xsd:string ;
    rdfs:label   "has title" ;
    rdfs:comment "The full title of the publication." .

arpo:hasAbstract
    a owl:DatatypeProperty , owl:FunctionalProperty ;
    rdfs:domain  arpo:Publication ;
    rdfs:range   xsd:string ;
    rdfs:label   "has abstract" ;
    rdfs:comment "The abstract or summary text of the publication." .

arpo:hasYear
    a owl:DatatypeProperty , owl:FunctionalProperty ;
    rdfs:domain  arpo:Publication ;
    rdfs:range   xsd:integer ;
    rdfs:label   "has year" ;
    rdfs:comment "The year in which the publication was published." .

arpo:hasDOI
    a owl:DatatypeProperty , owl:FunctionalProperty ;
    rdfs:domain  arpo:Publication ;
    rdfs:range   xsd:string ;
    rdfs:label   "has DOI" ;
    rdfs:comment "The Digital Object Identifier (DOI) of the publication." .

arpo:hasVolume
    a owl:DatatypeProperty ;
    rdfs:domain  arpo:JournalArticle ;
    rdfs:range   xsd:string ;
    rdfs:label   "has volume" ;
    rdfs:comment "The journal volume in which the article appears." .

arpo:hasIssue
    a owl:DatatypeProperty ;
    rdfs:domain  arpo:JournalArticle ;
    rdfs:range   xsd:string ;
    rdfs:label   "has issue" ;
    rdfs:comment "The journal issue in which the article appears." .

arpo:hasPageStart
    a owl:DatatypeProperty ;
    rdfs:domain  arpo:Publication ;
    rdfs:range   xsd:integer ;
    rdfs:label   "has page start" ;
    rdfs:comment "The first page number of the publication." .

arpo:hasPageEnd
    a owl:DatatypeProperty ;
    rdfs:domain  arpo:Publication ;
    rdfs:range   xsd:integer ;
    rdfs:label   "has page end" ;
    rdfs:comment "The last page number of the publication." .

arpo:hasCitationCount
    a owl:DatatypeProperty , owl:FunctionalProperty ;
    rdfs:domain  arpo:Publication ;
    rdfs:range   xsd:integer ;
    rdfs:label   "has citation count" ;
    rdfs:comment "The total number of times the publication has been cited." .

arpo:hasISSN
    a owl:DatatypeProperty , owl:FunctionalProperty ;
    rdfs:domain  arpo:Journal ;
    rdfs:range   xsd:string ;
    rdfs:label   "has ISSN" ;
    rdfs:comment "The International Standard Serial Number of the journal." .

arpo:hasImpactFactor
    a owl:DatatypeProperty , owl:FunctionalProperty ;
    rdfs:domain  arpo:Journal ;
    rdfs:range   xsd:decimal ;
    rdfs:label   "has impact factor" ;
    rdfs:comment "The current Journal Impact Factor (JIF) of the journal." .

arpo:hasName
    a owl:DatatypeProperty , owl:FunctionalProperty ;
    rdfs:domain  arpo:Person ;
    rdfs:range   xsd:string ;
    rdfs:label   "has name" ;
    rdfs:comment "The full name of the person." .

arpo:hasORCID
    a owl:DatatypeProperty , owl:FunctionalProperty ;
    rdfs:domain  arpo:Researcher ;
    rdfs:range   xsd:string ;
    rdfs:label   "has ORCID" ;
    rdfs:comment "The Open Researcher and Contributor ID (ORCID) of the researcher." .

arpo:hasLabel
    a owl:DatatypeProperty , owl:FunctionalProperty ;
    rdfs:domain  arpo:Keyword ;
    rdfs:range   xsd:string ;
    rdfs:label   "has label" ;
    rdfs:comment "The textual label of the keyword." .

arpo:hasTopicName
    a owl:DatatypeProperty , owl:FunctionalProperty ;
    rdfs:domain  arpo:ResearchTopic ;
    rdfs:range   xsd:string ;
    rdfs:label   "has topic name" ;
    rdfs:comment "The name of the research topic." .


# ─────────────────────────────────────────────────────────────────────────────
# DATA PROPERTIES — NEW v2
# ─────────────────────────────────────────────────────────────────────────────

# AffiliationRecord (MOMo record pattern — time bounds)
arpo:hasStartYear
    a owl:DatatypeProperty ;
    rdfs:domain  arpo:AffiliationRecord ;
    rdfs:range   xsd:integer ;
    rdfs:label   "has start year" ;
    rdfs:comment "The year in which the affiliation described by this record began." .

arpo:hasEndYear
    a owl:DatatypeProperty ;
    rdfs:domain  arpo:AffiliationRecord ;
    rdfs:range   xsd:integer ;
    rdfs:label   "has end year" ;
    rdfs:comment "The year in which the affiliation described by this record ended. Omitted if the affiliation is current." .

# Grant
arpo:hasGrantNumber
    a owl:DatatypeProperty , owl:FunctionalProperty ;
    rdfs:domain  arpo:Grant ;
    rdfs:range   xsd:string ;
    rdfs:label   "has grant number" ;
    rdfs:comment "The official award or grant number assigned by the funding body." .

# OpenAccessStatus (MOMo controlled vocabulary pattern)
arpo:hasAccessType
    a owl:DatatypeProperty , owl:FunctionalProperty ;
    rdfs:domain  arpo:OpenAccessStatus ;
    rdfs:range   xsd:string ;
    rdfs:label   "has access type" ;
    rdfs:comment "The open access type label. Expected values: gold, green, bronze, closed." .


# ─────────────────────────────────────────────────────────────────────────────
# CONTROLLED VOCABULARY INDIVIDUALS — OpenAccessStatus (v2)
# ─────────────────────────────────────────────────────────────────────────────

arpo:GoldOA
    a arpo:OpenAccessStatus ;
    arpo:hasAccessType "gold" ;
    rdfs:label   "Gold Open Access" ;
    rdfs:comment "Immediately freely available via the publisher under an open licence." .

arpo:GreenOA
    a arpo:OpenAccessStatus ;
    arpo:hasAccessType "green" ;
    rdfs:label   "Green Open Access" ;
    rdfs:comment "Self-archived in a repository (preprint or accepted manuscript)." .

arpo:BronzeOA
    a arpo:OpenAccessStatus ;
    arpo:hasAccessType "bronze" ;
    rdfs:label   "Bronze Open Access" ;
    rdfs:comment "Free to read on the publisher site but without an open licence." .

arpo:ClosedAccess
    a arpo:OpenAccessStatus ;
    arpo:hasAccessType "closed" ;
    rdfs:label   "Closed Access" ;
    rdfs:comment "Access is restricted; requires subscription or payment." .

[ a owl:AllDifferent ;
  owl:distinctMembers ( arpo:GoldOA arpo:GreenOA arpo:BronzeOA arpo:ClosedAccess ) ] .


# ─────────────────────────────────────────────────────────────────────────────
# EXAMPLE INSTANCES — v1 (retained) + v2 extensions
# ─────────────────────────────────────────────────────────────────────────────

# ── Research Topics ──────────────────────────────────────────────────────────

arpo:KnowledgeEngineering
    a arpo:ResearchTopic ;
    arpo:hasTopicName "Knowledge Engineering" .

arpo:SemanticWeb
    a arpo:ResearchTopic ;
    arpo:hasTopicName "Semantic Web" .

arpo:MachineLearning
    a arpo:ResearchTopic ;
    arpo:hasTopicName "Machine Learning" .


# ── Keywords ─────────────────────────────────────────────────────────────────

arpo:kw_ontology
    a arpo:Keyword ;
    arpo:hasLabel    "ontology" ;
    arpo:representsArea arpo:KnowledgeEngineering .

arpo:kw_owl
    a arpo:Keyword ;
    arpo:hasLabel    "OWL" ;
    arpo:representsArea arpo:SemanticWeb .

arpo:kw_linkeddata
    a arpo:Keyword ;
    arpo:hasLabel    "Linked Data" ;
    arpo:representsArea arpo:SemanticWeb .

arpo:kw_llm
    a arpo:Keyword ;
    arpo:hasLabel    "Large Language Model" ;
    arpo:representsArea arpo:MachineLearning .


# ── Institutions ─────────────────────────────────────────────────────────────

arpo:UniExampleA
    a arpo:University ;
    rdfs:label "Example University A" .

arpo:UniExampleB
    a arpo:University ;
    rdfs:label "Example University B" .

# NEW v2 — ResearchGroup instance
arpo:KnowledgeLabA
    a arpo:ResearchGroup ;
    rdfs:label "Knowledge Engineering Lab, Example University A" .


# ── Funding — NEW v2 ─────────────────────────────────────────────────────────

arpo:FunderNSF
    a arpo:FundingBody ;
    rdfs:label "National Science Foundation (NSF)" .

arpo:grant_arpo_2025
    a arpo:Grant ;
    arpo:hasGrantNumber "NSF-2025-KE-001" ;
    arpo:fundedBy       arpo:FunderNSF .


# ── Journals ─────────────────────────────────────────────────────────────────

arpo:JWebSemantics
    a arpo:Journal ;
    rdfs:label          "Journal of Web Semantics" ;
    arpo:hasISSN        "1570-8268" ;
    arpo:hasImpactFactor "3.2"^^xsd:decimal .


# ── Conference ───────────────────────────────────────────────────────────────

arpo:ISWC2025
    a arpo:Conference ;
    rdfs:label "24th International Semantic Web Conference (ISWC 2025)" .


# ── Authors ──────────────────────────────────────────────────────────────────

arpo:author_alice
    a arpo:Author ;
    arpo:hasName              "Alice Smith" ;
    arpo:hasORCID             "0000-0001-2345-6789" ;
    arpo:isAffiliatedWith     arpo:UniExampleA ;
    arpo:memberOf             arpo:KnowledgeLabA .

arpo:author_bob
    a arpo:Author ;
    arpo:hasName              "Bob Jones" ;
    arpo:hasORCID             "0000-0002-9876-5432" ;
    arpo:isAffiliatedWith     arpo:UniExampleB .

arpo:author_alice arpo:hasCoAuthor arpo:author_bob .

# NEW v2 — AffiliationRecord for alice (MOMo record pattern)
arpo:affRec_alice_A
    a arpo:AffiliationRecord ;
    arpo:affiliatedInstitution arpo:UniExampleA ;
    arpo:hasStartYear          2020 .

arpo:author_alice arpo:hasAffiliationRecord arpo:affRec_alice_A .


# ── Publications ─────────────────────────────────────────────────────────────

arpo:paper_001
    a arpo:JournalArticle ;
    arpo:hasTitle              "An Ontology for Academic Research Publications" ;
    arpo:hasAbstract           "We present ARPO, a formal OWL 2 DL ontology for representing the academic research publication domain, supporting semantic search and citation analysis." ;
    arpo:hasYear               2025 ;
    arpo:hasDOI                "10.1000/arpo.2025.001" ;
    arpo:hasVolume             "12" ;
    arpo:hasIssue              "3" ;
    arpo:hasPageStart          101 ;
    arpo:hasPageEnd            118 ;
    arpo:hasCitationCount      0 ;
    arpo:hasAuthor             arpo:author_alice , arpo:author_bob ;
    arpo:publishedIn           arpo:JWebSemantics ;
    arpo:hasResearchTopic      arpo:KnowledgeEngineering , arpo:SemanticWeb ;
    arpo:hasKeyword            arpo:kw_ontology , arpo:kw_owl , arpo:kw_linkeddata ;
    arpo:hasOpenAccessStatus   arpo:GoldOA ;
    arpo:hasFunding            arpo:grant_arpo_2025 .

arpo:paper_002
    a arpo:ConferencePaper ;
    arpo:hasTitle              "Competency Questions in Ontology Engineering: A Systematic Review" ;
    arpo:hasYear               2025 ;
    arpo:hasDOI                "10.1000/arpo.2025.002" ;
    arpo:hasPageStart          44 ;
    arpo:hasPageEnd            57 ;
    arpo:hasCitationCount      0 ;
    arpo:hasAuthor             arpo:author_alice ;
    arpo:publishedIn           arpo:ISWC2025 ;
    arpo:hasResearchTopic      arpo:KnowledgeEngineering ;
    arpo:hasKeyword            arpo:kw_ontology ;
    arpo:hasOpenAccessStatus   arpo:GreenOA .

# NEW v2 — Preprint instance
arpo:preprint_001
    a arpo:Preprint ;
    arpo:hasTitle              "LLM-Based Population of the ARPO Knowledge Graph: A Pilot Study" ;
    arpo:hasYear               2026 ;
