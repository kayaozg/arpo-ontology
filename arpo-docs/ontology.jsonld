}, {
  "@id" : "https://example.org/arpo",
  "@type" : [ "http://www.w3.org/2002/07/owl#Ontology" ],
  "http://purl.org/dc/terms/creator" : [ {
    "@value" : "Fırat Kaya Özgenç"
  } ],
  "http://purl.org/dc/terms/date" : [ {
    "@value" : "2026-05-05"
  } ],
  "http://purl.org/dc/terms/description" : [ {
    "@value" : "A formal OWL 2 DL ontology for representing academic research publications, authors, venues, institutions, citation relationships, funding, and open access status."
  } ],
  "http://purl.org/dc/terms/license" : [ {
    "@id" : "https://creativecommons.org/licenses/by/4.0/"
  } ],
  "http://purl.org/dc/terms/title" : [ {
    "@value" : "Academic Research Publication Ontology (ARPO)"
  } ],
  "http://www.w3.org/2002/07/owl#priorVersion" : [ {
    "@id" : "https://example.org/arpo/1.0"
  } ],
  "http://www.w3.org/2002/07/owl#versionIRI" : [ {
    "@id" : "https://example.org/arpo/2.0"
  } ],
  "http://www.w3.org/2004/02/skos/core#changeNote" : [ {
    "@value" : "v2.0: Added ResearchGroup, Grant, FundingBody, AffiliationRecord, OpenAccessStatus, PeerReviewRecord, Preprint classes. Added 6 new object properties and 4 new data properties. Modelling follows MOMo methodology with record and controlled-vocabulary patterns."
  } ]
}, {
  "@id" : "https://example.org/arpo#AffiliationRecord",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@value" : "A time-bounded record linking an Author to an Institution for a given period. Follows the MOMo record pattern, which reifies relationships that change over time."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#label" : [ {
    "@value" : "Affiliation Record"
  } ]
}, {
  "@id" : "https://example.org/arpo#Author",
