        <rdfs:label>Institution</rdfs:label>
    </owl:Class>
    


    <!-- https://example.org/arpo#Journal -->


    <owl:Class rdf:about="https://example.org/arpo#Journal">
        <rdfs:subClassOf rdf:resource="https://example.org/arpo#PublicationVenue"/>
        <rdfs:comment>A periodical publication containing peer-reviewed academic articles.</rdfs:comment>
