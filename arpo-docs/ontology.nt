# 
# https://example.org/arpo#AffiliationRecord
<https://example.org/arpo#AffiliationRecord> <http://www.w3.org/1999/02/22-rdf-syntax-ns#type> <http://www.w3.org/2002/07/owl#Class> .
<https://example.org/arpo#AffiliationRecord> <http://www.w3.org/2000/01/rdf-schema#comment> "A time-bounded record linking an Author to an Institution for a given period. Follows the MOMo record pattern, which reifies relationships that change over time." .
<https://example.org/arpo#AffiliationRecord> <http://www.w3.org/2000/01/rdf-schema#label> "Affiliation Record" .
# 
# https://example.org/arpo#Author
<https://example.org/arpo#Author> <http://www.w3.org/1999/02/22-rdf-syntax-ns#type> <http://www.w3.org/2002/07/owl#Class> .
<https://example.org/arpo#Author> <http://www.w3.org/2000/01/rdf-schema#subClassOf> <https://example.org/arpo#Researcher> .
<https://example.org/arpo#Author> <http://www.w3.org/2000/01/rdf-schema#comment> "A researcher who has authored one or more publications." .
<https://example.org/arpo#Author> <http://www.w3.org/2000/01/rdf-schema#label> "Author" .
# 
# https://example.org/arpo#BookChapter
<https://example.org/arpo#BookChapter> <http://www.w3.org/1999/02/22-rdf-syntax-ns#type> <http://www.w3.org/2002/07/owl#Class> .
<https://example.org/arpo#BookChapter> <http://www.w3.org/2000/01/rdf-schema#subClassOf> <https://example.org/arpo#Publication> .
<https://example.org/arpo#BookChapter> <http://www.w3.org/2000/01/rdf-schema#comment> "A chapter or section published within an edited academic book." .
<https://example.org/arpo#BookChapter> <http://www.w3.org/2000/01/rdf-schema#label> "Book Chapter" .
# 
# https://example.org/arpo#Citation
<https://example.org/arpo#Citation> <http://www.w3.org/1999/02/22-rdf-syntax-ns#type> <http://www.w3.org/2002/07/owl#Class> .
<https://example.org/arpo#Citation> <http://www.w3.org/2000/01/rdf-schema#comment> "A formal reference from one publication to another." .
<https://example.org/arpo#Citation> <http://www.w3.org/2000/01/rdf-schema#label> "Citation" .
# 
# https://example.org/arpo#Company
<https://example.org/arpo#Company> <http://www.w3.org/1999/02/22-rdf-syntax-ns#type> <http://www.w3.org/2002/07/owl#Class> .
<https://example.org/arpo#Company> <http://www.w3.org/2000/01/rdf-schema#subClassOf> <https://example.org/arpo#Institution> .
<https://example.org/arpo#Company> <http://www.w3.org/2000/01/rdf-schema#comment> "An industrial or commercial organisation engaged in research." .
<https://example.org/arpo#Company> <http://www.w3.org/2000/01/rdf-schema#label> "Company" .
# 
# https://example.org/arpo#Conference
<https://example.org/arpo#Conference> <http://www.w3.org/1999/02/22-rdf-syntax-ns#type> <http://www.w3.org/2002/07/owl#Class> .
<https://example.org/arpo#Conference> <http://www.w3.org/2000/01/rdf-schema#subClassOf> <https://example.org/arpo#PublicationVenue> .
<https://example.org/arpo#Conference> <http://www.w3.org/2002/07/owl#disjointWith> <https://example.org/arpo#Journal> .
<https://example.org/arpo#Conference> <http://www.w3.org/2000/01/rdf-schema#comment> "An academic event at which research papers are presented and published in proceedings." .
<https://example.org/arpo#Conference> <http://www.w3.org/2000/01/rdf-schema#label> "Conference" .
# 
# https://example.org/arpo#ConferencePaper
<https://example.org/arpo#ConferencePaper> <http://www.w3.org/1999/02/22-rdf-syntax-ns#type> <http://www.w3.org/2002/07/owl#Class> .
<https://example.org/arpo#ConferencePaper> <http://www.w3.org/2000/01/rdf-schema#subClassOf> <https://example.org/arpo#Publication> .
<https://example.org/arpo#ConferencePaper> <http://www.w3.org/2000/01/rdf-schema#comment> "A paper accepted and presented at an academic conference or workshop." .
<https://example.org/arpo#ConferencePaper> <http://www.w3.org/2000/01/rdf-schema#label> "Conference Paper" .
# 
# https://example.org/arpo#FundingBody
<https://example.org/arpo#FundingBody> <http://www.w3.org/1999/02/22-rdf-syntax-ns#type> <http://www.w3.org/2002/07/owl#Class> .
<https://example.org/arpo#FundingBody> <http://www.w3.org/2000/01/rdf-schema#comment> "An organisation that provides research funding, such as a national science foundation, charity, or government agency." .
<https://example.org/arpo#FundingBody> <http://www.w3.org/2000/01/rdf-schema#label> "Funding Body" .
# 
# https://example.org/arpo#Grant
<https://example.org/arpo#Grant> <http://www.w3.org/1999/02/22-rdf-syntax-ns#type> <http://www.w3.org/2002/07/owl#Class> .
<https://example.org/arpo#Grant> <http://www.w3.org/2000/01/rdf-schema#comment> "A funded research grant associated with one or more publications." .
<https://example.org/arpo#Grant> <http://www.w3.org/2000/01/rdf-schema#label> "Grant" .
# 
# https://example.org/arpo#Institution
<https://example.org/arpo#Institution> <http://www.w3.org/1999/02/22-rdf-syntax-ns#type> <http://www.w3.org/2002/07/owl#Class> .
<https://example.org/arpo#Institution> <http://www.w3.org/2000/01/rdf-schema#comment> "An organisation with which researchers may be affiliated." .
<https://example.org/arpo#Institution> <http://www.w3.org/2000/01/rdf-schema#label> "Institution" .
# 
# https://example.org/arpo#Journal
<https://example.org/arpo#Journal> <http://www.w3.org/1999/02/22-rdf-syntax-ns#type> <http://www.w3.org/2002/07/owl#Class> .
<https://example.org/arpo#Journal> <http://www.w3.org/2000/01/rdf-schema#subClassOf> <https://example.org/arpo#PublicationVenue> .
<https://example.org/arpo#Journal> <http://www.w3.org/2000/01/rdf-schema#comment> "A periodical publication containing peer-reviewed academic articles." .
<https://example.org/arpo#Journal> <http://www.w3.org/2000/01/rdf-schema#label> "Journal" .
# 
# https://example.org/arpo#JournalArticle
<https://example.org/arpo#JournalArticle> <http://www.w3.org/1999/02/22-rdf-syntax-ns#type> <http://www.w3.org/2002/07/owl#Class> .
<https://example.org/arpo#JournalArticle> <http://www.w3.org/2000/01/rdf-schema#subClassOf> <https://example.org/arpo#Publication> .
<https://example.org/arpo#JournalArticle> <http://www.w3.org/2000/01/rdf-schema#comment> "A peer-reviewed article published in a scholarly journal." .
<https://example.org/arpo#JournalArticle> <http://www.w3.org/2000/01/rdf-schema#label> "Journal Article" .
# 
# https://example.org/arpo#Keyword
<https://example.org/arpo#Keyword> <http://www.w3.org/1999/02/22-rdf-syntax-ns#type> <http://www.w3.org/2002/07/owl#Class> .
<https://example.org/arpo#Keyword> <http://www.w3.org/2000/01/rdf-schema#comment> "A term or phrase assigned to a publication to describe its content." .
<https://example.org/arpo#Keyword> <http://www.w3.org/2000/01/rdf-schema#label> "Keyword" .
# 
# https://example.org/arpo#OpenAccessStatus
<https://example.org/arpo#OpenAccessStatus> <http://www.w3.org/1999/02/22-rdf-syntax-ns#type> <http://www.w3.org/2002/07/owl#Class> .
<https://example.org/arpo#OpenAccessStatus> <http://www.w3.org/2000/01/rdf-schema#comment> "The open access category of a publication. Controlled vocabulary: gold, green, bronze, closed. Follows the MOMo controlled-vocabulary (purple-box) pattern." .
<https://example.org/arpo#OpenAccessStatus> <http://www.w3.org/2000/01/rdf-schema#label> "Open Access Status" .
# 
# https://example.org/arpo#PeerReviewRecord
<https://example.org/arpo#PeerReviewRecord> <http://www.w3.org/1999/02/22-rdf-syntax-ns#type> <http://www.w3.org/2002/07/owl#Class> .
<https://example.org/arpo#PeerReviewRecord> <http://www.w3.org/2000/01/rdf-schema#comment> "A record capturing the peer-review status of a publication, including whether it was reviewed and at which venue. Follows the MOMo provenance pattern." .
<https://example.org/arpo#PeerReviewRecord> <http://www.w3.org/2000/01/rdf-schema#label> "Peer Review Record" .
# 
# https://example.org/arpo#Person
<https://example.org/arpo#Person> <http://www.w3.org/1999/02/22-rdf-syntax-ns#type> <http://www.w3.org/2002/07/owl#Class> .
<https://example.org/arpo#Person> <http://www.w3.org/2000/01/rdf-schema#comment> "A human being involved in academic research activities." .
<https://example.org/arpo#Person> <http://www.w3.org/2000/01/rdf-schema#label> "Person" .
# 
# https://example.org/arpo#Preprint
<https://example.org/arpo#Preprint> <http://www.w3.org/1999/02/22-rdf-syntax-ns#type> <http://www.w3.org/2002/07/owl#Class> .
<https://example.org/arpo#Preprint> <http://www.w3.org/2000/01/rdf-schema#subClassOf> <https://example.org/arpo#Publication> .
<https://example.org/arpo#Preprint> <http://www.w3.org/2000/01/rdf-schema#comment> "A version of a research paper made publicly available before formal peer review, typically deposited on a preprint server such as arXiv or bioRxiv." .
<https://example.org/arpo#Preprint> <http://www.w3.org/2000/01/rdf-schema#label> "Preprint" .
# 
# https://example.org/arpo#Publication
<https://example.org/arpo#Publication> <http://www.w3.org/1999/02/22-rdf-syntax-ns#type> <http://www.w3.org/2002/07/owl#Class> .
<https://example.org/arpo#Publication> <http://www.w3.org/2000/01/rdf-schema#comment> "The top-level class for all types of academic research outputs." .
<https://example.org/arpo#Publication> <http://www.w3.org/2000/01/rdf-schema#label> "Publication" .
# 
# https://example.org/arpo#PublicationVenue
<https://example.org/arpo#PublicationVenue> <http://www.w3.org/1999/02/22-rdf-syntax-ns#type> <http://www.w3.org/2002/07/owl#Class> .
<https://example.org/arpo#PublicationVenue> <http://www.w3.org/2000/01/rdf-schema#comment> "A channel or forum where academic research is formally published or presented." .
<https://example.org/arpo#PublicationVenue> <http://www.w3.org/2000/01/rdf-schema#label> "Publication Venue" .
# 
# https://example.org/arpo#Publisher
<https://example.org/arpo#Publisher> <http://www.w3.org/1999/02/22-rdf-syntax-ns#type> <http://www.w3.org/2002/07/owl#Class> .
<https://example.org/arpo#Publisher> <http://www.w3.org/2000/01/rdf-schema#comment> "An organisation responsible for producing and distributing publications." .
<https://example.org/arpo#Publisher> <http://www.w3.org/2000/01/rdf-schema#label> "Publisher" .
# 
# https://example.org/arpo#ResearchGroup
<https://example.org/arpo#ResearchGroup> <http://www.w3.org/1999/02/22-rdf-syntax-ns#type> <http://www.w3.org/2002/07/owl#Class> .
<https://example.org/arpo#ResearchGroup> <http://www.w3.org/2000/01/rdf-schema#subClassOf> <https://example.org/arpo#Institution> .
<https://example.org/arpo#ResearchGroup> <http://www.w3.org/2000/01/rdf-schema#comment> "A named research group or laboratory operating within a university or research institute." .
<https://example.org/arpo#ResearchGroup> <http://www.w3.org/2000/01/rdf-schema#label> "Research Group" .
# 
# https://example.org/arpo#ResearchInstitute
<https://example.org/arpo#ResearchInstitute> <http://www.w3.org/1999/02/22-rdf-syntax-ns#type> <http://www.w3.org/2002/07/owl#Class> .
<https://example.org/arpo#ResearchInstitute> <http://www.w3.org/2000/01/rdf-schema#subClassOf> <https://example.org/arpo#Institution> .
<https://example.org/arpo#ResearchInstitute> <http://www.w3.org/2000/01/rdf-schema#comment> "A dedicated research organisation, not necessarily degree-granting." .
<https://example.org/arpo#ResearchInstitute> <http://www.w3.org/2000/01/rdf-schema#label> "Research Institute" .
# 
# https://example.org/arpo#ResearchTopic
<https://example.org/arpo#ResearchTopic> <http://www.w3.org/1999/02/22-rdf-syntax-ns#type> <http://www.w3.org/2002/07/owl#Class> .
<https://example.org/arpo#ResearchTopic> <http://www.w3.org/2000/01/rdf-schema#comment> "A subject area or thematic domain of academic research." .
<https://example.org/arpo#ResearchTopic> <http://www.w3.org/2000/01/rdf-schema#label> "Research Topic" .
# 
# https://example.org/arpo#Researcher
<https://example.org/arpo#Researcher> <http://www.w3.org/1999/02/22-rdf-syntax-ns#type> <http://www.w3.org/2002/07/owl#Class> .
<https://example.org/arpo#Researcher> <http://www.w3.org/2000/01/rdf-schema#subClassOf> <https://example.org/arpo#Person> .
<https://example.org/arpo#Researcher> <http://www.w3.org/2000/01/rdf-schema#comment> "A person who conducts academic research." .
<https://example.org/arpo#Researcher> <http://www.w3.org/2000/01/rdf-schema#label> "Researcher" .
# 
# https://example.org/arpo#Reviewer
<https://example.org/arpo#Reviewer> <http://www.w3.org/1999/02/22-rdf-syntax-ns#type> <http://www.w3.org/2002/07/owl#Class> .
<https://example.org/arpo#Reviewer> <http://www.w3.org/2000/01/rdf-schema#subClassOf> <https://example.org/arpo#Researcher> .
<https://example.org/arpo#Reviewer> <http://www.w3.org/2000/01/rdf-schema#comment> "A researcher who peer-reviews academic manuscripts." .
<https://example.org/arpo#Reviewer> <http://www.w3.org/2000/01/rdf-schema#label> "Reviewer" .
# 
# https://example.org/arpo#TechnicalReport
<https://example.org/arpo#TechnicalReport> <http://www.w3.org/1999/02/22-rdf-syntax-ns#type> <http://www.w3.org/2002/07/owl#Class> .
<https://example.org/arpo#TechnicalReport> <http://www.w3.org/2000/01/rdf-schema#subClassOf> <https://example.org/arpo#Publication> .
<https://example.org/arpo#TechnicalReport> <http://www.w3.org/2000/01/rdf-schema#comment> "A formal report describing the results or progress of technical research." .
<https://example.org/arpo#TechnicalReport> <http://www.w3.org/2000/01/rdf-schema#label> "Technical Report" .
# 
# https://example.org/arpo#Thesis
<https://example.org/arpo#Thesis> <http://www.w3.org/1999/02/22-rdf-syntax-ns#type> <http://www.w3.org/2002/07/owl#Class> .
<https://example.org/arpo#Thesis> <http://www.w3.org/2000/01/rdf-schema#subClassOf> <https://example.org/arpo#Publication> .
<https://example.org/arpo#Thesis> <http://www.w3.org/2000/01/rdf-schema#comment> "A doctoral dissertation or master's thesis submitted to an academic institution." .
<https://example.org/arpo#Thesis> <http://www.w3.org/2000/01/rdf-schema#label> "Thesis" .
# 
# https://example.org/arpo#University
<https://example.org/arpo#University> <http://www.w3.org/1999/02/22-rdf-syntax-ns#type> <http://www.w3.org/2002/07/owl#Class> .
<https://example.org/arpo#University> <http://www.w3.org/2000/01/rdf-schema#subClassOf> <https://example.org/arpo#Institution> .
<https://example.org/arpo#University> <http://www.w3.org/2000/01/rdf-schema#comment> "A higher-education institution that conducts research." .
<https://example.org/arpo#University> <http://www.w3.org/2000/01/rdf-schema#label> "University" .
# 
# https://example.org/arpo#Workshop
<https://example.org/arpo#Workshop> <http://www.w3.org/1999/02/22-rdf-syntax-ns#type> <http://www.w3.org/2002/07/owl#Class> .
<https://example.org/arpo#Workshop> <http://www.w3.org/2000/01/rdf-schema#subClassOf> <https://example.org/arpo#Conference> .
<https://example.org/arpo#Workshop> <http://www.w3.org/2000/01/rdf-schema#comment> "A smaller, more focused academic event often co-located with a major conference." .
<https://example.org/arpo#Workshop> <http://www.w3.org/2000/01/rdf-schema#label> "Workshop" .
